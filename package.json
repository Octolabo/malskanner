{
  "name": "malskanner",
  "version": "0.1.1",
  "description": "Scan a repo for hidden prompt-injection payloads before your AI agent trusts it.",
  "type": "module",
  "bin": {
    "malskanner": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "scan": "tsx src/cli.ts",
    "mcp": "tsx src/mcp.ts",
    "fixtures": "node scripts/make-fixtures.mjs",
    "scan:demo": "tsx src/cli.ts test/fixtures/poisoned",
    "test": "node scripts/make-fixtures.mjs && node --import tsx --test test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "prompt-injection",
    "mcp",
    "ai-security",
    "llm-security",
    "claude-code",
    "security-scanner"
  ],
  "license": "MIT",
  "author": "octolabo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/octolabo/malskanner.git"
  },
  "bugs": {
    "url": "https://github.com/octolabo/malskanner/issues"
  },
  "homepage": "https://github.com/octolabo/malskanner#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.4",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
